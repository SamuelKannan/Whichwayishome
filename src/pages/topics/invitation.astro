---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTopic } from '../../data/topics';

const topic = getTopic('invitation');
---

<BaseLayout title={`${topic.title} | Which Way is Home`} description={topic.description} ogType="article">
  <main class="invitation-main">
    <div class="invitation-card reveal in">
      <div class="invitation-border">
        <span class="invitation-flourish" aria-hidden="true">✦</span>

        <section class="invitation-section">
          <h1>Invitation:</h1>
          <p>“Everyone who calls on the name of the Lord will be saved.” - Romans 10:13</p>
        </section>

        <section class="invitation-section">
          <h1>How to RSVP:</h1>
          <p>
            "If you declare with your mouth, “Jesus is Lord,” and believe in your heart that God
            raised him from the dead, you will be saved." - Romans 10:9
          </p>
        </section>

        <section class="invitation-section">
          <h1>Confirmation:</h1>
          <p>
            "Very truly I tell you, whoever hears my word and believes him who sent me has
            eternal life and will not be judged but has crossed over from death to life." - John 5:24
          </p>
        </section>

        <p class="invitation-promise">
          “Do not let your hearts be troubled. You believe in God ; believe also in me. My Father’s house has
          many rooms; if that were not so, would I have told you that I am going there to prepare a place for
          you? And if I go and prepare a place for you, I will come back and take you to be with me that you
          also may be where I am. You know the way to the place where I am going.” - John 14:1-4
        </p>

        <p class="invitation-promise">
          "But in keeping with his promise we are looking forward to a new heaven and a new earth, where
          righteousness dwells." - 2 Peter 3:13
        </p>

        <span class="invitation-flourish" aria-hidden="true">✦</span>
      </div>
    </div>

    <p class="back-home">
      <a href="/topics/heaven/">← Back to Heaven</a>
    </p>
  </main>
</BaseLayout>

<style>
  .invitation-main {
    padding: 3.5rem 1.25rem 1rem;
  }

  .invitation-card {
    max-width: 680px;
    margin: 0 auto;
    background: var(--surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 0.9rem;
  }

  .invitation-border {
    border: 2px solid var(--gold);
    outline: 1px solid var(--gold-soft);
    outline-offset: 5px;
    border-radius: calc(var(--radius-lg) - 6px);
    padding: 2.8rem clamp(1.4rem, 5vw, 3rem);
    text-align: center;
  }

  .invitation-flourish {
    display: block;
    color: var(--gold);
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .invitation-border > .invitation-flourish:last-child {
    margin-bottom: 0;
    margin-top: 1.5rem;
  }

  .invitation-section {
    margin-bottom: 2.2rem;
  }

  .invitation-section h1 {
    font-size: clamp(2rem, 5vw, 2.6rem);
    color: var(--accent-deep);
    margin-bottom: 0.6rem;
  }

  .invitation-section p {
    font-size: 1.15rem;
    color: var(--ink-soft);
  }

  .invitation-promise {
    margin: 1.6rem auto 0;
    max-width: 50ch;
    font-style: italic;
    color: var(--ink-soft);
    border-top: 1px solid var(--line);
    padding-top: 1.6rem;
  }

  .back-home {
    text-align: center;
    padding: 2.5rem 0 0.5rem;
  }

  .back-home a {
    font-weight: 600;
    text-decoration: none;
  }
</style>
