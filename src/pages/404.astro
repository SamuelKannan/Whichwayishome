---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found | Which Way is Home"
  description="This page could not be found. Find your way back home."
  noindex
>
  <main class="notfound">
    <p class="eyebrow">404</p>
    <h1>This road doesn't lead anywhere</h1>
    <p>The page you're looking for doesn't exist — but the way home is always open.</p>
    <a href="/" class="btn btn-primary">← Back to Home</a>
  </main>
</BaseLayout>

<style>
  .notfound {
    min-height: 55vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    text-align: center;
    padding: 3rem 1.25rem;
  }

  .notfound h1 {
    font-size: clamp(2.2rem, 6vw, 3.4rem);
  }

  .notfound p {
    color: var(--ink-soft);
  }
</style>
